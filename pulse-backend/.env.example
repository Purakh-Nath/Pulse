# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/pulse

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (generate with: openssl rand -hex 32) ────────────────────────────────
JWT_ACCESS_SECRET=change_me_use_openssl_rand_hex_32_access
JWT_REFRESH_SECRET=change_me_use_openssl_rand_hex_32_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/auth/callback

# ─── Security ─────────────────────────────────────────────────────────────────
CSRF_SECRET=change_me_use_openssl_rand_hex_32_csrf
COOKIE_SECRET=change_me_use_openssl_rand_hex_32_cookie
ANON_TOKEN_SECRET=change_me_use_openssl_rand_hex_32_anon

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
